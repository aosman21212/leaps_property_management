<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="seq_rental_contract" model="ir.sequence">
            <field name="name">Rental Contract</field>
            <field name="code">property.rental.contract</field>
            <field name="prefix">RC/%(year)s/</field>
            <field name="padding">4</field>
        </record>
        <record id="seq_sales_contract" model="ir.sequence">
            <field name="name">Sales Contract</field>
            <field name="code">property.sales.contract</field>
            <field name="prefix">SC/%(year)s/</field>
            <field name="padding">4</field>
        </record>
        <record id="seq_commission" model="ir.sequence">
            <field name="name">Property Commission</field>
            <field name="code">property.commission</field>
            <field name="prefix">CM/%(year)s/</field>
            <field name="padding">4</field>
        </record>
        <record id="seq_maintenance_request" model="ir.sequence">
            <field name="name">Maintenance Request</field>
            <field name="code">property.maintenance</field>
            <field name="prefix">MC/%(year)s/</field>
            <field name="padding">4</field>
        </record>
    </data>
</odoo>
