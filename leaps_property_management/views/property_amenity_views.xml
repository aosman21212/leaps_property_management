<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_property_amenity_list" model="ir.ui.view">
        <field name="name">property.amenity.list</field>
        <field name="model">property.amenity</field>
        <field name="arch" type="xml">
            <list string="المرافق" editable="bottom">
                <field name="name"/>
                <field name="icon"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_property_amenity_form" model="ir.ui.view">
        <field name="name">property.amenity.form</field>
        <field name="model">property.amenity</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="icon"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_property_amenity" model="ir.actions.act_window">
        <field name="name">المرافق</field>
        <field name="res_model">property.amenity</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
