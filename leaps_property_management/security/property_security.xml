<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">
        <!-- Property Management privilege (groups category) -->
        <record id="privilege_property" model="res.groups.privilege">
            <field name="name">Property Management</field>
            <field name="sequence">55</field>
        </record>
        <!-- Agent group: read-only access -->
        <record id="group_property_user" model="res.groups">
            <field name="name">وكيل</field>
            <field name="privilege_id" ref="privilege_property"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>
        <!-- Manager group: read/create/write access, implies Agent -->
        <record id="group_property_manager" model="res.groups">
            <field name="name">مدير</field>
            <field name="privilege_id" ref="privilege_property"/>
            <field name="implied_ids" eval="[(4, ref('group_property_user'))]"/>
        </record>
        <!-- Admin group: full access including delete, implies Manager -->
        <record id="group_property_admin" model="res.groups">
            <field name="name">مدير عام</field>
            <field name="privilege_id" ref="privilege_property"/>
            <field name="implied_ids" eval="[(4, ref('group_property_manager'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>
    </data>
</odoo>
