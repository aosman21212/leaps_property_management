<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Kanban View -->
    <record id="view_property_unit_kanban" model="ir.ui.view">
        <field name="name">property.unit.kanban</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" default_group_by="state">
                <field name="name"/>
                <field name="property_type"/>
                <field name="building_id"/>
                <field name="state"/>
                <field name="rent_amount"/>
                <field name="sale_price"/>
                <field name="city"/>
                <field name="bedrooms"/>
                <field name="bathrooms"/>
                <field name="area_sqft"/>
                <field name="image_small"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="card">
                        <div class="row g-0">
                            <div t-if="record.image_small.value" class="col-auto">
                                <img t-att-src="record.image_small.value" class="o_kanban_image" style="width:64px;height:64px;object-fit:cover;border-radius:4px;margin-right:8px;" alt="عقار"/>
                            </div>
                            <div class="col">
                                <strong><field name="name"/></strong>
                                <div class="text-muted"><field name="property_type"/></div>
                                <div t-if="record.building_id.value" class="small text-muted">
                                    <i class="fa fa-building-o" title="مبنى"/> <field name="building_id"/>
                                </div>
                                <div t-if="record.city.value">
                                    <i class="fa fa-map-marker" title="المدينة"/> <field name="city"/>
                                </div>
                                <div class="d-flex gap-2 mt-1">
                                    <span t-if="record.bedrooms.value">
                                        <i class="fa fa-bed" title="غرف النوم"/> <field name="bedrooms"/>
                                    </span>
                                    <span t-if="record.bathrooms.value">
                                        <i class="fa fa-bath" title="دورات المياه"/> <field name="bathrooms"/>
                                    </span>
                                    <span t-if="record.area_sqft.value">
                                        <i class="fa fa-arrows" title="المساحة"/> <field name="area_sqft"/> قدم مربع
                                    </span>
                                </div>
                                <div class="mt-1">
                                    <span class="badge"
                                        t-att-class="{
                                            'bg-success': record.state.raw_value == 'available',
                                            'bg-warning text-dark': record.state.raw_value == 'booked',
                                            'bg-info': record.state.raw_value == 'rented',
                                            'bg-danger': record.state.raw_value == 'sold',
                                            'bg-secondary': record.state.raw_value == 'maintenance'
                                        }">
                                        <field name="state"/>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- List View -->
    <record id="view_property_unit_list" model="ir.ui.view">
        <field name="name">property.unit.list</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <list string="الوحدات العقارية"
                decoration-success="state == 'available'"
                decoration-info="state == 'rented'"
                decoration-warning="state == 'booked'"
                decoration-danger="state == 'sold'">
                <field name="name"/>
                <field name="building_id" optional="show"/>
                <field name="property_type"/>
                <field name="building"/>
                <field name="floor"/>
                <field name="unit_number"/>
                <field name="city"/>
                <field name="area_sqft"/>
                <field name="bedrooms"/>
                <field name="bathrooms"/>
                <field name="rent_amount"/>
                <field name="sale_price"/>
                <field name="state" widget="badge"
                    decoration-success="state == 'available'"
                    decoration-info="state == 'rented'"
                    decoration-warning="state == 'booked'"
                    decoration-danger="state == 'sold'"/>
                <field name="owner_id"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_property_unit_form" model="ir.ui.view">
        <field name="name">property.unit.form</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <form string="الوحدة العقارية">
                <header>
                    <button name="action_set_available" string="تعيين كمتاح" type="object"
                        class="btn-primary" invisible="state == 'available'"/>
                    <button name="action_view_rental_contracts" string="عقد إيجار جديد"
                        type="object" class="btn-secondary"
                        invisible="state not in ['available']"/>
                    <button name="action_set_maintenance" string="تحت الصيانة"
                        type="object" invisible="state == 'maintenance'"/>
                    <field name="state" widget="statusbar"
                        statusbar_visible="available,booked,rented,sold"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button class="oe_stat_button" type="object"
                            name="action_view_rental_contracts" icon="fa-file-text-o">
                            <field name="rental_contract_count" widget="statinfo"
                                string="عقود الإيجار"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                            name="action_view_sales_contracts" icon="fa-handshake-o">
                            <field name="sales_contract_count" widget="statinfo"
                                string="عقود البيع"/>
                        </button>
                        <button class="oe_stat_button" type="object"
                            name="action_view_maintenance" icon="fa-wrench">
                            <field name="maintenance_count" widget="statinfo"
                                string="الصيانة"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar"
                        options="{'preview_image': 'image_small'}"/>
                    <div class="oe_title">
                        <h1><field name="name" placeholder="اسم الوحدة / المرجع"/></h1>
                        <h2><field name="ref" placeholder="رمز المرجع"/></h2>
                    </div>
                    <group>
                        <group string="تفاصيل العقار">
                            <field name="building_id"/>
                            <field name="property_type"/>
                            <field name="unit_type"/>
                            <field name="building"/>
                            <field name="floor"/>
                            <field name="unit_number"/>
                            <field name="furnishing"/>
                            <field name="facing"/>
                        </group>
                        <group string="المالك">
                            <field name="owner_id"/>
                            <field name="current_tenant_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="المواصفات">
                            <group>
                                <group string="الحجم والتخطيط">
                                    <field name="area_sqft"/>
                                    <field name="area_sqm" readonly="1"/>
                                    <field name="bedrooms"/>
                                    <field name="bathrooms"/>
                                    <field name="balconies"/>
                                    <field name="parking_spaces"/>
                                </group>
                                <group string="التسعير">
                                    <field name="currency_id" invisible="1"/>
                                    <field name="rent_amount"/>
                                    <field name="sale_price"/>
                                    <field name="security_deposit"/>
                                </group>
                            </group>
                        </page>
                        <page string="الموقع">
                            <group>
                                <group>
                                    <field name="street"/>
                                    <field name="city"/>
                                    <field name="zip_code"/>
                                </group>
                                <group>
                                    <field name="state_id"/>
                                    <field name="country_id"/>
                                </group>
                            </group>
                        </page>
                        <page string="المرافق">
                            <field name="amenity_ids" widget="many2many_tags"/>
                        </page>
                        <page string="ملاحظات">
                            <field name="notes" placeholder="ملاحظات إضافية حول هذا العقار..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="view_property_unit_search" model="ir.ui.view">
        <field name="name">property.unit.search</field>
        <field name="model">property.unit</field>
        <field name="arch" type="xml">
            <search string="بحث العقارات">
                <field name="name"/>
                <field name="building_id"/>
                <field name="city"/>
                <field name="owner_id"/>
                <field name="property_type"/>
                <separator/>
                <filter string="متاح" name="available" domain="[('state','=','available')]"/>
                <filter string="مؤجر" name="rented" domain="[('state','=','rented')]"/>
                <filter string="مباع" name="sold" domain="[('state','=','sold')]"/>
                <filter string="محجوز" name="booked" domain="[('state','=','booked')]"/>
                <separator/>
                <filter string="شقة" name="apartment" domain="[('property_type','=','apartment')]"/>
                <filter string="فيلا" name="villa" domain="[('property_type','=','villa')]"/>
                <filter string="تجاري" name="commercial" domain="[('property_type','=','commercial')]"/>
                <group>
                    <filter string="الحالة" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="النوع" name="group_type" context="{'group_by': 'property_type'}"/>
                    <filter string="المبنى" name="group_building" context="{'group_by': 'building_id'}"/>
                    <filter string="المدينة" name="group_city" context="{'group_by': 'city'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_property_unit" model="ir.actions.act_window">
        <field name="name">العقارات</field>
        <field name="res_model">property.unit</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'search_default_available': 1}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">أضف أول وحدة عقارية</p>
        </field>
    </record>
</odoo>
